{
  "id": "palworld",
  "name": "Palworld",
  "category": "Survival",
  "icon": "🧭",
  "description": "Servidor Palworld dedicado via SteamCMD com password, admin e portas isoladas.",
  "installer": "steamcmd-palworld",
  "defaultResources": {
    "ramMb": 8192,
    "cpuLimit": 200,
    "diskMb": 25000
  },
  "ports": [
    { "name": "Game", "port": 8211, "protocol": "udp" },
    { "name": "RCON", "port": 27015, "protocol": "tcp" }
  ],
  "schema": [
    { "key": "serverName", "label": "Nome do servidor", "type": "text", "default": "Palworld Node", "required": true },
    { "key": "port", "label": "Porta", "type": "number", "default": 8211, "min": 1024, "max": 65535 },
    { "key": "serverPassword", "label": "Password servidor", "type": "password", "default": "", "required": false },
    { "key": "adminPassword", "label": "Password admin", "type": "password", "default": "", "required": false },
    { "key": "ramMb", "label": "RAM MB", "type": "number", "default": 8192, "min": 4096, "max": 65536 }
  ],
  "status": "available"
}
