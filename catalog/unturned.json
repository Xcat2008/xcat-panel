{
  "id": "unturned",
  "name": "Unturned",
  "category": "Survival",
  "icon": "🧱",
  "description": "Servidor Unturned dedicado com SteamCMD, mapa, slots e modo de jogo editaveis.",
  "installer": "steamcmd-unturned",
  "defaultResources": {
    "ramMb": 2048,
    "cpuLimit": 100,
    "diskMb": 8000
  },
  "ports": [
    { "name": "Game", "port": 27015, "protocol": "udp" },
    { "name": "Query", "port": 27016, "protocol": "udp" }
  ],
  "schema": [
    { "key": "serverName", "label": "Nome do servidor", "type": "text", "default": "Unturned Node", "required": true },
    { "key": "maxPlayers", "label": "Slots", "type": "number", "default": 24, "min": 2, "max": 64 },
    { "key": "port", "label": "Porta", "type": "number", "default": 27015, "min": 1024, "max": 65535 },
    { "key": "map", "label": "Mapa", "type": "text", "default": "PEI", "required": true },
    { "key": "mode", "label": "Modo", "type": "select", "default": "normal", "options": [
      { "label": "Easy", "value": "easy" },
      { "label": "Normal", "value": "normal" },
      { "label": "Hard", "value": "hard" }
    ]},
    { "key": "ramMb", "label": "RAM MB", "type": "number", "default": 2048, "min": 1024, "max": 16384 }
  ],
  "status": "available"
}
