{
  "id": "cs2",
  "name": "Counter-Strike 2",
  "category": "FPS",
  "icon": "🎯",
  "description": "Servidor Counter-Strike 2 com SteamCMD, consola, ficheiros, configs, modos e controlo live.",
  "installer": "steamcmd-cs2",
  "defaultResources": {
    "ramMb": 8192,
    "cpuLimit": 250,
    "diskMb": 50000
  },
  "ports": [
    { "name": "Game", "port": 27015, "protocol": "udp" },
    { "name": "CSTV", "port": 27020, "protocol": "udp" }
  ],
  "schema": [
    { "key": "serverName", "label": "Nome do servidor", "type": "text", "default": "Counter-Strike 2 Node", "required": true },
    { "key": "maxPlayers", "label": "Slots", "type": "number", "default": 12, "min": 2, "max": 64 },
    { "key": "port", "label": "Porta", "type": "number", "default": 27015, "min": 1024, "max": 65535 },
    { "key": "tvPort", "label": "Porta CSTV", "type": "number", "default": 27020, "min": 1024, "max": 65535 },
    { "key": "map", "label": "Mapa inicial", "type": "text", "default": "de_dust2" },
    { "key": "gslt", "label": "Steam GSLT", "type": "password", "default": "", "required": false },
    { "key": "rconPassword", "label": "RCON password", "type": "password", "default": "", "required": false },
    { "key": "serverPassword", "label": "Password do servidor", "type": "password", "default": "", "required": false },
    { "key": "ramMb", "label": "RAM MB", "type": "number", "default": 8192, "min": 4096, "max": 65536 }
  ],
  "status": "available"
}

